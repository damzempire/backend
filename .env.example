# Soroban Network Configuration
SOROBAN_RPC_URL=https://rpc.mainnet.stellar.org
SOROBAN_HORIZON_URL=https://horizon.stellar.org

# Lag Threshold Configuration
LAG_THRESHOLD_SECONDS=300
MONITORING_INTERVAL_SECONDS=60
ALERT_COOLDOWN_SECONDS=900

# Alerting Configuration
WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
ALERT_EMAIL_RECIPIENTS=admin@example.com,ops@example.com

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/indexer.log

# Shadow-Indexing Configuration
SHADOW_INDEXING_ENABLED=true
SHADOW_INDEXING_INTERVAL=3000
SHADOW_VALIDATION_INTERVAL=30
CRITICAL_INCONSISTENCY_COUNT=5
WARNING_INCONSISTENCY_COUNT=2
FAILOVER_THRESHOLD=10
AUTO_FAILOVER=false
SYNC_ON_STARTUP=true
